{
  "permissions": {
    "allow": [
      "Bash(git mv *)",
      "Bash(git rm *)"
    ]
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File \"${CLAUDE_PROJECT_DIR}\\.claude\\hooks\\claude_turn_logger.ps1\"",
            "commandWindows": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File \"${CLAUDE_PROJECT_DIR}\\.claude\\hooks\\claude_turn_logger.ps1\"",
            "timeout": 30,
            "statusMessage": "Logging prompt"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File \"${CLAUDE_PROJECT_DIR}\\.claude\\hooks\\claude_turn_logger.ps1\"",
            "commandWindows": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File \"${CLAUDE_PROJECT_DIR}\\.claude\\hooks\\claude_turn_logger.ps1\"",
            "timeout": 30,
            "statusMessage": "Logging turn result"
          }
        ]
      }
    ]
  }
}
